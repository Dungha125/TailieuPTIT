# Production — copy thành .env trên server rồi chỉnh giá trị
ENVIRONMENT=production

POSTGRES_USER=tailieuptit
POSTGRES_PASSWORD=doi-mat-khau-manh-o-day
POSTGRES_DB=tailieuptit

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=doi-mat-khau-minio-manh

REDIS_PASSWORD=doi-mat-khau-redis-manh

JWT_SECRET_KEY=doi-chuoi-bi-mat-jwt-dai-va-ngau-nhien
JWT_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_PASSWORD=doi-mat-khau-admin-manh

# Domain frontend trên Vercel (HTTPS, phân cách bằng dấu phẩy)
CORS_ORIGINS=https://tenban.vercel.app,https://tenban.com
TRUSTED_HOSTS=api.tenban.com
DOMAIN=api.tenban.com
STORAGE_QUOTA_GB=60
SITE_URL=https://tailieuptit.lcdkhoacntt1.com

# Security
ENABLE_HSTS=true
RATE_LIMIT_FAIL_CLOSED=true
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_LOGIN=5
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_SEARCH=60
RATE_LIMIT_BAN_SECONDS=1800
LOGIN_MAX_ATTEMPTS=5
LOGIN_BAN_SECONDS=1800

# Optional: Cloudflare Turnstile (bảo vệ login)
# TURNSTILE_SECRET_KEY=

# Mã hóa payload API (DevTools chỉ thấy ciphertext)
# Tạo key: openssl rand -base64 32
ENABLE_API_PAYLOAD_ENCRYPTION=true
API_PAYLOAD_ENCRYPTION_KEY=thay-bang-key-base64-32-bytes
